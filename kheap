#!/usr/bin/env bash
# ==============================================================================
# kheap
#
# Purpose:
#   Collect a JVM thread dump and heap dump from a Kubernetes pod.
#
# Operating modes:
#   1) DIRECT mode
#      Try to execute diagnostics directly inside the target container
#      using tools already present there (jcmd or jattach).
#
#   2) DEBUG mode
#      If DIRECT mode is unavailable or fails, fall back to a reusable
#      ephemeral toolbox container named "kheap", using jattach from that
#      container.
#
# Dry-run (default):
#   Without --force the script validates all inputs, detects the Java PID,
#   checks remote and local disk space, and prints what it would do.
#   No heap dump is created, no ephemeral container is injected, no signal
#   is sent to the JVM. Pass --force to execute for real.
#
# Thread dump collection (--force only, cascading):
#   1. jcmd Thread.print        (DIRECT, if jcmd available in target container)
#   2. jattach threaddump       (DEBUG container, if running or after creation)
#   3. kill -3 + kubectl logs   (universal fallback, any image)
#   If all three methods fail, a warning is emitted and execution continues.
#
# Behavior:
#   - Validates namespace, pod, target container and required local commands
#   - Auto-detects Java PID if not explicitly provided
#   - Checks remote and local disk space before any write
#   - Collects thread dump (cascading, best-effort) [--force only]
#   - Creates heap dump inside the target container filesystem [--force only]
#   - Copies the heap dump locally [--force only]
#   - Verifies local/remote size match (+ optional checksum) [--force only]
#   - Compresses locally with gzip [--force only]
#   - Removes the remote heap dump after successful copy [--force only]
#
# Notes:
#   - DIRECT mode is best-effort only: application containers may not
#     contain the required Java diagnostic tools
#   - DEBUG mode is the supported fallback for tool-poor images
#   - Thread dump is always attempted regardless of --direct-only / --debug-only
#   - collect_thread_dump is called AFTER mode selection, so when running in
#     AUTO or DEBUG mode the debug container is guaranteed to be up before
#     thread dump method 2 (jattach) is attempted
#   - PID detection falls back to /proc scan for BusyBox images where
#     ps -eo is unavailable
#
# Requirements:
#   - kubectl configured and authorized
#   - local commands: kubectl awk grep date gzip
#   - DEBUG mode toolbox image must contain jattach
#
# Usage:
#   ./kheap -n <namespace> -p <pod> [-c <container>] \
#       [-P <java_pid>] [-i <toolbox_image>] [-r <remote_dir>] \
#       [-o <output_dir>] [--no-gzip] [--keep-remote] [--checksum] \
#       [--direct-only] [--debug-only] [--force]
#
# Examples:
#   ./kheap -n pt-healthcheck -p fanny-547bb857d8-jq59m
#   ./kheap -n pt-healthcheck -p fanny-547bb857d8-jq59m --force
#   ./kheap -n pt-healthcheck -p fanny-547bb857d8-jq59m -c app --force
#   ./kheap -n pt-healthcheck -p fanny-547bb857d8-jq59m --direct-only --force
#   ./kheap -n pt-healthcheck -p fanny-547bb857d8-jq59m --debug-only --force
#   ./kheap -n pt-healthcheck -p fanny-547bb857d8-jq59m --checksum --force
#
# Default toolbox image:
#   registry.dasrn.generali.it/gbs/spring-boot-demo:kheap
# ==============================================================================

set -euo pipefail

NS=""
POD=""
CONTAINER=""
JAVA_PID=""
REMOTE_DIR="/tmp"
OUTPUT_DIR="."
NO_GZIP=false
KEEP_REMOTE=false
DIRECT_ONLY=false
DEBUG_ONLY=false
CHECKSUM=false
DRY_RUN=true

DEFAULT_IMAGE="registry.dasrn.generali.it/gbs/spring-boot-demo:kheap"
TOOL_IMAGE="${KHEAP_IMAGE:-$DEFAULT_IMAGE}"

DEBUG_CONTAINER="kheap"

TS="$(date +%Y%m%d%H%M%S)"
REMOTE_HPROF=""
LOCAL_HPROF=""
LOCAL_GZ=""
FINAL_FILE=""

# Globals mutated by run_direct_mode / run_debug_mode:
#   MODE_USED   - "DIRECT" or "DEBUG"
#   JAVA_PID    - resolved Java PID (may be overwritten from auto-detect)
MODE_USED=""

# Globals mutated by collect_thread_dump:
#   THREAD_DUMP_FILE     - path to saved thread dump file (empty if not collected)
#   THREAD_DUMP_METHOD   - human-readable label of the method used
#   THREAD_DUMP_COMPLETE - true only after thread dump is fully written and verified non-empty
THREAD_DUMP_FILE=""
THREAD_DUMP_METHOD=""
THREAD_DUMP_COMPLETE=false

# REMOTE_SIZE: set by verify_local_space (actual bytes after dump), reused by verify_size
# to avoid a redundant wc -c exec on the remote container.
REMOTE_SIZE=""

# EST_DUMP_SIZE: set by verify_remote_space (RSS-based estimate, bytes).
# Used by verify_local_space in dry-run mode when no actual file exists yet.
EST_DUMP_SIZE=""

# Track whether the final output file is complete and safe to keep.
# Set to true only after copy + verify succeed.
OUTPUT_COMPLETE=false

usage() {
  cat <<EOF
Usage: $0 -n <namespace> -p <pod> [-c <container>] [-P <pid>] [-i <image>] [-r <remote_dir>] [-o <output_dir>] [--no-gzip] [--keep-remote] [--checksum] [--direct-only] [--debug-only] [--force]

Options:
  -n <namespace>     Kubernetes namespace
  -p <pod>           Pod name
  -c <container>     Target container name (default: auto-detect first container)
  -P <pid>           Java PID (default: auto-detect)
  -i <image>         Toolbox image for DEBUG mode ephemeral container
  -r <remote_dir>    Remote directory inside target container (default: /tmp)
  -o <output_dir>    Local output directory (default: current directory)
  --no-gzip          Do not compress the local heap dump
  --keep-remote      Keep the remote heap dump file after successful copy
  --checksum         Verify MD5 checksum after copy (in addition to size check)
  --direct-only      Use DIRECT mode only, do not fall back to DEBUG mode
  --debug-only       Use DEBUG mode only, skip DIRECT mode
  --force            Execute for real (default: dry-run, no writes, no signals)
  -h, --help         Show this help

Dry-run (default):
  Without --force the script validates all inputs, detects the Java PID,
  checks remote and local disk space, and prints what it would do.
  No heap dump is created, no ephemeral container is injected, no signal
  is sent to the JVM.

Environment:
  KHEAP_IMAGE        Override default toolbox image

Thread dump (--force only):
  Always attempted before the heap dump, in cascading order:
    1. jcmd Thread.print  (if available in target container)
    2. jattach threaddump (via debug container)
    3. kill -3 + kubectl logs (universal fallback, --since=60s)
  Failure is non-fatal: a warning is emitted and execution continues.

Notes:
  - --checksum uses md5sum (Linux) or md5 (macOS) automatically.
EOF
}

log()  { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"; }
warn() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] WARNING: $*" >&2; }
die()  { echo "ERROR: $*" >&2; exit 1; }

require_cmd() {
  local missing=0
  for cmd in "$@"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      echo "ERROR: Required command not found: $cmd" >&2
      missing=1
    fi
  done
  [[ "$missing" -eq 0 ]] || exit 1
}

# -----------------------------
# Cleanup on error
#
# Removes partial local files ONLY if the output was not yet marked complete.
# Thread dump files are removed only if THREAD_DUMP_COMPLETE is false,
# meaning the file may be partial. A fully written thread dump is preserved
# even when the heap dump copy subsequently fails.
# The final compressed file is never removed here: if we reached compression,
# the data was already verified and the uncompressed source is gone.
# -----------------------------
cleanup_on_error() {
  local rc=$?
  [[ $rc -eq 0 ]] && exit 0

  log "Script failed (rc=$rc). Cleaning up partial files..."

  if [[ "$OUTPUT_COMPLETE" = false ]]; then
    if [[ -n "${LOCAL_HPROF:-}" && -f "$LOCAL_HPROF" ]]; then
      log "Removing partial local file: $LOCAL_HPROF"
      rm -f "$LOCAL_HPROF" || true
    fi
    if [[ -n "${LOCAL_GZ:-}" && -f "$LOCAL_GZ" ]]; then
      log "Removing partial compressed file: $LOCAL_GZ"
      rm -f "$LOCAL_GZ" || true
    fi
  fi

  if [[ "$THREAD_DUMP_COMPLETE" = false && -n "${THREAD_DUMP_FILE:-}" && -f "$THREAD_DUMP_FILE" ]]; then
    log "Removing partial thread dump file: $THREAD_DUMP_FILE"
    rm -f "$THREAD_DUMP_FILE" || true
  fi

  exit $rc
}

trap cleanup_on_error EXIT

# -----------------------------
# Parse args
# -----------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    -n) NS="$2"; shift 2 ;;
    -p) POD="$2"; shift 2 ;;
    -c) CONTAINER="$2"; shift 2 ;;
    -P) JAVA_PID="$2"; shift 2 ;;
    -i) TOOL_IMAGE="$2"; shift 2 ;;
    -r) REMOTE_DIR="$2"; shift 2 ;;
    -o) OUTPUT_DIR="$2"; shift 2 ;;
    --no-gzip)     NO_GZIP=true;     shift 1 ;;
    --keep-remote) KEEP_REMOTE=true; shift 1 ;;
    --checksum)    CHECKSUM=true;    shift 1 ;;
    --direct-only) DIRECT_ONLY=true; shift 1 ;;
    --debug-only)  DEBUG_ONLY=true;  shift 1 ;;
    --force)       DRY_RUN=false;    shift 1 ;;
    -h|--help) usage; exit 0 ;;
    *) usage; die "Unknown argument: $1" ;;
  esac
done

[[ -z "$NS" || -z "$POD" ]] && { usage; die "Namespace and pod are required."; }
[[ "$DIRECT_ONLY" = true && "$DEBUG_ONLY" = true ]] && die "--direct-only and --debug-only are mutually exclusive."

require_cmd kubectl awk grep date gzip

if [[ "$DRY_RUN" = true ]]; then
  log "[DRY-RUN] Validation and space checks only. Pass --force to execute."
fi

log "Using kheap image: $TOOL_IMAGE"

# -----------------------------
# Detect local md5 command (Linux vs macOS)
# -----------------------------
LOCAL_MD5_CMD=""
if [[ "$CHECKSUM" = true ]]; then
  if command -v md5sum >/dev/null 2>&1; then
    LOCAL_MD5_CMD="md5sum"
  elif command -v md5 >/dev/null 2>&1; then
    LOCAL_MD5_CMD="md5 -q"
  else
    warn "--checksum requested but neither md5sum nor md5 found locally. Skipping checksum."
    CHECKSUM=false
  fi
fi

# -----------------------------
# Validate local output dir
# -----------------------------
mkdir -p "$OUTPUT_DIR" || die "Cannot create output directory: $OUTPUT_DIR"
[[ -d "$OUTPUT_DIR" ]] || die "Output path is not a directory: $OUTPUT_DIR"
[[ -w "$OUTPUT_DIR" ]] || die "Output directory is not writable: $OUTPUT_DIR"

# -----------------------------
# Validate pod
# -----------------------------
kubectl -n "$NS" get pod "$POD" >/dev/null || die "Pod not found."

PHASE="$(kubectl -n "$NS" get pod "$POD" -o jsonpath='{.status.phase}')"
[[ "$PHASE" != "Running" ]] && die "Pod is not Running (phase=$PHASE)."
log "Pod phase: $PHASE"

if [[ -z "$CONTAINER" ]]; then
  CONTAINER="$(kubectl -n "$NS" get pod "$POD" -o jsonpath='{.spec.containers[0].name}')"
  [[ -z "$CONTAINER" ]] && die "Could not auto-detect target container name."
  log "Auto-detected target container: $CONTAINER"
else
  log "Target container: $CONTAINER"
fi

kubectl -n "$NS" get pod "$POD" -o jsonpath="{.spec.containers[?(@.name=='$CONTAINER')].name}" | grep -qx "$CONTAINER" \
  || die "Target container '$CONTAINER' not found in pod '$POD'."

REMOTE_HPROF="${REMOTE_DIR%/}/heap_${NS}_${POD}_${TS}.hprof"
LOCAL_HPROF="${OUTPUT_DIR%/}/${NS}_${POD}_${TS}.hprof"
LOCAL_GZ="${LOCAL_HPROF}.gz"
FINAL_FILE="$LOCAL_HPROF"

# -----------------------------
# Common helpers
# -----------------------------

# In dry-run mode: only checks existence and writability, does not create.
# In --force mode: creates the directory if missing, then verifies.
validate_remote_dir() {
  log "Validating remote directory on target container: $REMOTE_DIR"
  if [[ "$DRY_RUN" = true ]]; then
    kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- sh -c "
      test -d '$REMOTE_DIR' &&
      test -w '$REMOTE_DIR'
    " >/dev/null || return 1
  else
    kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- sh -c "
      mkdir -p '$REMOTE_DIR' &&
      test -d '$REMOTE_DIR' &&
      test -w '$REMOTE_DIR'
    " >/dev/null || return 1
  fi
}

# Matches only the java binary (absolute or basename) to avoid false positives
# from processes like 'javaagent-wrapper' or 'java-service-proxy'.
# Falls back to /proc scan for BusyBox environments where ps -eo is unavailable.
detect_java_pid_in_container() {
  kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- sh -c '
    pid="$(ps -eo pid,args 2>/dev/null | awk "\$2==\"java\" || \$2 ~ /\/java$/ {print \$1; exit}")"
    if [ -z "$pid" ]; then
      for d in /proc/[0-9]*; do
        comm="$(cat "$d/comm" 2>/dev/null || true)"
        [ "$comm" = "java" ] && { pid="${d#/proc/}"; break; }
      done
    fi
    echo "$pid"
  ' 2>/dev/null || true
}

# Uses 'test -s' instead of 'ls': verifies existence and non-zero size,
# more reliable across minimal shell environments.
verify_remote_file_exists() {
  kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- sh -c "test -s '$REMOTE_HPROF'" >/dev/null 2>&1
}

copy_heap_dump() {
  if kubectl -n "$NS" cp "$POD:$REMOTE_HPROF" "$LOCAL_HPROF" -c "$CONTAINER" >/dev/null 2>&1; then
    return 0
  fi

  # Fallback: pipe directly without a shell to avoid profile script contamination
  # of the binary hprof stream.
  log "kubectl cp failed, trying fallback via cat..."
  kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- cat "$REMOTE_HPROF" > "$LOCAL_HPROF"
}

# -----------------------------
# Size verification
#
# Reuses REMOTE_SIZE set by verify_local_space to avoid a redundant
# wc -c exec on the remote container. Falls back to re-measuring if
# verify_local_space was skipped or failed.
# -----------------------------
verify_size() {
  local local_size

  log "Verifying remote/local file size..."

  if [[ -z "$REMOTE_SIZE" ]]; then
    REMOTE_SIZE="$(kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- \
      sh -c "wc -c < '$REMOTE_HPROF'" 2>/dev/null | tr -d '[:space:]')"
  fi
  [[ -n "$REMOTE_SIZE" ]] || die "Could not determine remote heap dump size."

  local_size="$(wc -c < "$LOCAL_HPROF" | tr -d '[:space:]')"
  [[ -n "$local_size" ]] || die "Could not determine local heap dump size."

  [[ "$REMOTE_SIZE" = "$local_size" ]] || die "Size mismatch after copy: remote=$REMOTE_SIZE local=$local_size"
  log "Size verification OK: $local_size bytes"
}

# -----------------------------
# MD5 checksum verification (optional, --checksum)
# Uses md5sum on Linux, md5 -q on macOS.
# Guards against silent truncation from the cat fallback copy path.
# -----------------------------
verify_checksum() {
  [[ "$CHECKSUM" = false ]] && return 0

  log "Verifying MD5 checksum..."

  local remote_md5 local_md5

  remote_md5="$(kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- sh -c \
    "md5sum '$REMOTE_HPROF' 2>/dev/null | awk '{print \$1}' || md5 -q '$REMOTE_HPROF' 2>/dev/null || true" \
    2>/dev/null | tr -d '[:space:]')"

  if [[ -z "$remote_md5" ]]; then
    warn "Remote md5 not available (no md5sum/md5 in container). Skipping checksum."
    return 0
  fi

  local_md5="$($LOCAL_MD5_CMD "$LOCAL_HPROF" 2>/dev/null | awk '{print $1}' | tr -d '[:space:]')"
  [[ -n "$local_md5" ]] || { warn "Could not compute local MD5. Skipping checksum."; return 0; }

  [[ "$remote_md5" = "$local_md5" ]] || die "MD5 mismatch after copy: remote=$remote_md5 local=$local_md5"
  log "MD5 checksum OK: $local_md5"
}

# gzip -6: better speed/ratio tradeoff than -9 for large hprof files.
compress_local_file() {
  if [[ "$NO_GZIP" = false ]]; then
    log "Compressing locally..."
    gzip -6 -f "$LOCAL_HPROF"
    FINAL_FILE="$LOCAL_GZ"
    ls -lh "$FINAL_FILE"
  else
    FINAL_FILE="$LOCAL_HPROF"
  fi
}

cleanup_remote_file() {
  if [[ "$KEEP_REMOTE" = false ]]; then
    log "Removing remote heap dump: $REMOTE_HPROF"
    kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- sh -c "rm -f '$REMOTE_HPROF'" \
      || warn "Remote file cleanup failed."
  else
    log "Keeping remote heap dump as requested."
  fi
}

# -----------------------------
# verify_remote_space
#
# Estimates heap dump size from process RSS (VmRSS in /proc/<pid>/status)
# and checks available space in REMOTE_DIR inside the target container.
# Called after PID detection, before the dump is created, in both dry-run
# and --force mode.
#
# Sets EST_DUMP_SIZE (bytes) for reuse by verify_local_space in dry-run mode.
# -----------------------------
verify_remote_space() {
  local pid="$1"
  local rss_kb remote_free

  log "Checking remote disk space (RSS estimate)..."

  rss_kb="$(kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- \
    sh -c "awk '/VmRSS/ {print \$2}' /proc/$pid/status" 2>/dev/null | tr -d '[:space:]')"

  if [[ -z "$rss_kb" ]]; then
    warn "Cannot read VmRSS for PID $pid, skipping remote space check."
    return 0
  fi

  EST_DUMP_SIZE=$(( rss_kb * 1024 ))

  remote_free="$(kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- \
    sh -c "df -Pk '$REMOTE_DIR' | awk 'NR==2 {print \$4 * 1024}'" 2>/dev/null | tr -d '[:space:]')"

  if [[ -z "$remote_free" ]]; then
    warn "Cannot determine free space in $REMOTE_DIR, skipping remote space check."
    return 0
  fi

  (( remote_free > EST_DUMP_SIZE )) || \
    die "Insufficient space in $REMOTE_DIR on pod: estimated dump ~$EST_DUMP_SIZE bytes, free $remote_free bytes. Use -r to point to a larger volume."

  log "Remote space OK: estimated dump ~$EST_DUMP_SIZE bytes, free $remote_free bytes."
}

# -----------------------------
# verify_local_space
#
# --force mode: reads actual dump size from the remote file (sets REMOTE_SIZE
#   global for reuse by verify_size), checks local free space.
# Dry-run mode: uses EST_DUMP_SIZE set by verify_remote_space.
#
# Without --no-gzip: requires 2x file size locally (hprof + gz coexist during
# compression). With --no-gzip: 10% margin.
# -----------------------------
verify_local_space() {
  local size local_free needed

  if [[ "$DRY_RUN" = false ]]; then
    REMOTE_SIZE="$(kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- \
      sh -c "wc -c < '$REMOTE_HPROF'" 2>/dev/null | tr -d '[:space:]')"
    [[ -n "$REMOTE_SIZE" ]] || { warn "Cannot determine remote dump size, skipping local space check."; return 0; }
    size="$REMOTE_SIZE"
  else
    if [[ -z "$EST_DUMP_SIZE" ]]; then
      warn "No dump size estimate available, skipping local space check."
      return 0
    fi
    size="$EST_DUMP_SIZE"
    log "Local space check using RSS-based estimate: $size bytes."
  fi

  local_free="$(df -Pk "$OUTPUT_DIR" | awk 'NR==2 {print $4 * 1024}')"
  [[ -n "$local_free" ]] || { warn "Cannot determine local free space, skipping check."; return 0; }

  if [[ "$NO_GZIP" = false ]]; then
    needed=$(( size * 2 ))
  else
    needed=$(( size + size / 10 ))
  fi

  (( local_free > needed )) || \
    die "Insufficient local space in $OUTPUT_DIR: need ~$needed bytes, have $local_free bytes."

  log "Local space OK: need ~$needed bytes, free $local_free bytes."
}

# -----------------------------
# copy_with_retries
#
# Uses an explicit counter loop instead of brace expansion {1..3} to avoid
# unreliable arithmetic exit codes under set -euo pipefail.
# 3 retries are sufficient given the pre-flight space check.
# -----------------------------
copy_with_retries() {
  local attempt=0
  local max=3

  log "Copying heap dump locally to: $LOCAL_HPROF"

  while (( attempt < max )); do
    (( attempt++ )) || true
    if copy_heap_dump; then
      break
    fi
    if (( attempt == max )); then
      die "Copy failed after $max retries."
    fi
    log "Copy failed. Retrying ($attempt/$max) in 5s..."
    rm -f "$LOCAL_HPROF" || true
    sleep 5
  done

  [[ -f "$LOCAL_HPROF" ]] || die "Local heap dump file not found after copy."
  ls -lh "$LOCAL_HPROF"
}

# -----------------------------
# Thread dump collection (--force mode only)
# Always attempted, cascading:
#   1. jcmd Thread.print       (target container, DIRECT)
#   2. jattach threaddump      (debug container)
#   3. kill -3 + kubectl logs  (universal fallback)
# Non-fatal: warns and returns on failure.
#
# Mutates globals: THREAD_DUMP_FILE, THREAD_DUMP_METHOD, THREAD_DUMP_COMPLETE
#
# NOTE: called AFTER mode selection (heap dump), so when running in AUTO or
# DEBUG mode the debug container is already running by the time method 2 is
# attempted. No race condition.
# -----------------------------
is_debug_container_running() {
  kubectl -n "$NS" get pod "$POD" \
    -o jsonpath="{range .status.ephemeralContainerStatuses[*]}{.name}:{.state.running.startedAt}{'\n'}{end}" \
    2>/dev/null | awk -F: -v c="$DEBUG_CONTAINER" '$1==c && $2!="" {found=1} END {exit !found}'
}

collect_thread_dump() {
  local pid="$1"
  local out_file="${OUTPUT_DIR%/}/${NS}_${POD}_${TS}_threaddump.log"

  log "Collecting thread dump for PID $pid..."

  # ------------------------------------------------------------------
  # Method 1: jcmd inside target container (skip if --debug-only)
  # Uses sh -lc to pick up jcmd from PATH configured in login profile.
  # ------------------------------------------------------------------
  if [[ "$DEBUG_ONLY" != true ]]; then
    if kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- \
        sh -lc 'command -v jcmd >/dev/null 2>&1' 2>/dev/null; then
      log "Thread dump method 1: jcmd Thread.print (target container)..."
      if kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- \
          sh -lc "jcmd '$pid' Thread.print" > "$out_file" 2>/dev/null \
          && [[ -s "$out_file" ]]; then
        THREAD_DUMP_FILE="$out_file"
        THREAD_DUMP_METHOD="jcmd (DIRECT)"
        THREAD_DUMP_COMPLETE=true
        log "Thread dump saved: $out_file"
        return 0
      fi
      warn "Thread dump method 1 (jcmd) failed, trying next..."
      rm -f "$out_file" || true
    fi
  fi

  # ------------------------------------------------------------------
  # Method 2: jattach threaddump via debug container (skip if --direct-only)
  # The debug container is guaranteed to be running at this point when
  # in AUTO or DEBUG mode.
  # ------------------------------------------------------------------
  if [[ "$DIRECT_ONLY" != true ]]; then
    if is_debug_container_running; then
      log "Thread dump method 2: jattach threaddump (debug container)..."
      if kubectl -n "$NS" exec "$POD" -c "$DEBUG_CONTAINER" -- \
          sh -lc "jattach '$pid' threaddump" > "$out_file" 2>/dev/null \
          && [[ -s "$out_file" ]]; then
        THREAD_DUMP_FILE="$out_file"
        THREAD_DUMP_METHOD="jattach (DEBUG container)"
        THREAD_DUMP_COMPLETE=true
        log "Thread dump saved: $out_file"
        return 0
      fi
      warn "Thread dump method 2 (jattach) failed, trying next..."
      rm -f "$out_file" || true
    else
      log "Thread dump method 2: debug container not running, skipping jattach."
    fi
  fi

  # ------------------------------------------------------------------
  # Method 3: kill -3 (SIGQUIT) + kubectl logs capture.
  # Works on any image as long as exec is allowed.
  #
  # Uses --since=60s instead of --since-time to avoid clock skew between
  # the local machine and cluster nodes causing log lines to be missed.
  #
  # IMPORTANT: Verify PID visibility in the target container's PID namespace
  # before sending SIGQUIT. If JAVA_PID was auto-detected from the debug
  # container (which may share the host PID namespace), the PID could differ
  # inside the target container.
  # ------------------------------------------------------------------
  log "Thread dump method 3: kill -3 (SIGQUIT) + kubectl logs capture..."

  if ! kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- \
      sh -c "ls /proc/$pid/exe >/dev/null 2>&1" 2>/dev/null; then
    warn "PID $pid not visible in target container's PID namespace. Skipping kill -3."
    warn "Thread dump not collected."
    return 0
  fi

  if ! kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- \
      sh -c "kill -3 '$pid'" 2>/dev/null; then
    warn "Thread dump method 3 (kill -3) failed: could not send SIGQUIT."
    warn "Thread dump not collected."
    return 0
  fi

  log "SIGQUIT sent. Waiting 3s for JVM to write thread dump to stdout..."
  sleep 3

  if kubectl -n "$NS" logs "$POD" -c "$CONTAINER" \
      --since=60s > "$out_file" 2>/dev/null \
      && [[ -s "$out_file" ]]; then
    THREAD_DUMP_FILE="$out_file"
    THREAD_DUMP_METHOD="kill -3 / SIGQUIT (stdout capture)"
    THREAD_DUMP_COMPLETE=true
    log "Thread dump saved: $out_file"
    return 0
  fi

  rm -f "$out_file" || true
  warn "Thread dump method 3 (kubectl logs capture) produced empty output."
  warn "Thread dump not collected."
  return 0
}

# -----------------------------
# DIRECT mode helpers
# -----------------------------

# Uses sh -lc to pick up jcmd/jattach from login-profile PATH in the container.
direct_detect_tool() {
  kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- sh -lc '
    if command -v jcmd >/dev/null 2>&1; then
      echo jcmd
    elif command -v jattach >/dev/null 2>&1; then
      echo jattach
    else
      echo none
    fi
  ' 2>/dev/null || true
}

# Mutates globals: JAVA_PID, MODE_USED
run_direct_mode() {
  local tool=""
  local pid=""

  log "Trying DIRECT mode on target container..."

  validate_remote_dir || {
    warn "DIRECT mode: remote directory validation failed."
    return 1
  }

  tool="$(direct_detect_tool)"
  [[ -n "$tool" ]] || tool="none"

  if [[ "$tool" = "none" ]]; then
    warn "DIRECT mode: neither jcmd nor jattach found in target container."
    return 1
  fi

  log "DIRECT mode: detected tool: $tool"

  if [[ -n "$JAVA_PID" ]]; then
    pid="$JAVA_PID"
  else
    log "DIRECT mode: detecting Java PID in target container..."
    pid="$(detect_java_pid_in_container)"
    [[ -n "$pid" ]] || {
      warn "DIRECT mode: could not auto-detect Java PID."
      return 1
    }
  fi

  log "DIRECT mode: using Java PID: $pid"

  verify_remote_space "$pid"

  if [[ "$DRY_RUN" = true ]]; then
    if [[ "$tool" = "jcmd" ]]; then
      log "[DRY-RUN] Would run: jcmd '$pid' GC.heap_dump '$REMOTE_HPROF'"
    else
      log "[DRY-RUN] Would run: jattach '$pid' dumpheap '$REMOTE_HPROF'"
    fi
    JAVA_PID="$pid"
    MODE_USED="DIRECT"
    return 0
  fi

  if [[ "$tool" = "jcmd" ]]; then
    log "DIRECT mode: creating heap dump with jcmd at: $REMOTE_HPROF"
    kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- sh -lc \
      "jcmd '$pid' GC.heap_dump '$REMOTE_HPROF'" >/dev/null || {
        warn "DIRECT mode: jcmd heap dump failed."
        return 1
      }
  else
    log "DIRECT mode: creating heap dump with jattach at: $REMOTE_HPROF"
    kubectl -n "$NS" exec "$POD" -c "$CONTAINER" -- sh -lc \
      "jattach '$pid' dumpheap '$REMOTE_HPROF'" >/dev/null || {
        warn "DIRECT mode: jattach heap dump failed."
        return 1
      }
  fi

  verify_remote_file_exists || {
    warn "DIRECT mode: heap dump file not found after dump."
    return 1
  }

  JAVA_PID="$pid"
  MODE_USED="DIRECT"
  return 0
}

# -----------------------------
# DEBUG mode helpers
# -----------------------------

# ensure_debug_container_running
#
# Only called in --force mode. In dry-run mode this function is skipped entirely:
# no ephemeral container is injected.
# Checks whether the ephemeral debug container already exists and is running.
# If it exists but is not running (terminated/waiting), dies with a clear message.
# If it does not exist, creates it via kubectl debug and waits up to 120s.
# Detects unexpected termination during the wait loop and dies immediately.
ensure_debug_container_running() {
  local exists_in_spec=""
  local running_state=""
  local running=""
  local eph_status=""
  local debug_output=""

  log "DEBUG mode: ensuring reusable debug container exists..."

  exists_in_spec="$(kubectl -n "$NS" get pod "$POD" -o jsonpath="{range .spec.ephemeralContainers[*]}{.name}{'\n'}{end}" 2>/dev/null | grep -x "${DEBUG_CONTAINER}" || true)"
  running_state="$(kubectl -n "$NS" get pod "$POD" -o jsonpath="{range .status.ephemeralContainerStatuses[*]}{.name}:{.state.running.startedAt}{'\n'}{end}" 2>/dev/null | grep "^${DEBUG_CONTAINER}:" || true)"

  if [[ -n "$running_state" && "$running_state" != "${DEBUG_CONTAINER}:" ]]; then
    log "DEBUG mode: reusing running debug container: $DEBUG_CONTAINER"
    return 0
  fi

  if [[ -n "$exists_in_spec" ]]; then
    log "DEBUG mode: ephemeral container '$DEBUG_CONTAINER' already exists in spec."
    eph_status="$(kubectl -n "$NS" get pod "$POD" -o jsonpath="{range .status.ephemeralContainerStatuses[*]}{.name} state={.state} lastState={.lastState}{'\n'}{end}" 2>/dev/null || true)"
    [[ -n "$eph_status" ]] && echo "$eph_status" >&2
    die "Ephemeral container '$DEBUG_CONTAINER' exists but is NOT running. Recreate the pod (kubectl -n $NS delete pod $POD) and retry."
  fi

  log "DEBUG mode: creating debug container '$DEBUG_CONTAINER'..."
  if ! debug_output="$(
    kubectl -n "$NS" debug "pod/$POD" \
      --profile=general \
      --image="$TOOL_IMAGE" \
      --target="$CONTAINER" \
      --container="$DEBUG_CONTAINER" \
      --quiet \
      -- sh -c "sleep infinity" 2>&1
  )"; then
    echo "$debug_output" >&2
    die "kubectl debug failed."
  fi

  [[ -n "$debug_output" ]] && echo "$debug_output"

  log "DEBUG mode: waiting for debug container '$DEBUG_CONTAINER' to be Running (max 120s)..."

  local i=0
  local max_wait=60  # iterations x 2s = 120s
  while (( i < max_wait )); do
    (( i++ )) || true

    eph_status="$(kubectl -n "$NS" get pod "$POD" \
      -o jsonpath="{range .status.ephemeralContainerStatuses[*]}{.name} running={.state.running.startedAt} waiting={.state.waiting.reason} terminated={.state.terminated.reason}{'\n'}{end}" \
      2>/dev/null || true)"
    [[ -n "$eph_status" ]] && log "DEBUG mode status check $i/$max_wait: $(echo "$eph_status" | tr '\n' '; ')"

    if echo "$eph_status" | grep -q "^${DEBUG_CONTAINER} .*terminated=[^[:space:]]"; then
      kubectl -n "$NS" describe pod "$POD" >&2 || true
      die "Debug container '$DEBUG_CONTAINER' terminated unexpectedly. Check image or cluster policy."
    fi

    running="$(kubectl -n "$NS" get pod "$POD" \
      -o jsonpath="{range .status.ephemeralContainerStatuses[*]}{.name}:{.state.running.startedAt}{'\n'}{end}" \
      2>/dev/null | awk -F: -v c="$DEBUG_CONTAINER" '$1==c && $2!="" {print $2}')"
    [[ -n "$running" ]] && break

    if (( i == max_wait )); then
      kubectl -n "$NS" describe pod "$POD" >&2 || true
      die "Timeout waiting for debug container '$DEBUG_CONTAINER' to start (120s elapsed)."
    fi

    sleep 2
  done

  log "DEBUG mode: debug container '$DEBUG_CONTAINER' is Running."
}

# Falls back to /proc scan for BusyBox environments where ps -eo is unavailable.
# If PID is not visible from the debug container (different PID namespace),
# falls back to detection inside the target container.
debug_detect_java_pid() {
  local pid=""

  pid="$(kubectl -n "$NS" exec "$POD" -c "$DEBUG_CONTAINER" -- sh -c '
    pid="$(ps -eo pid,args 2>/dev/null | awk "\$2==\"java\" || \$2 ~ /\/java$/ {print \$1; exit}")"
    if [ -z "$pid" ]; then
      for d in /proc/[0-9]*; do
        comm="$(cat "$d/comm" 2>/dev/null || true)"
        [ "$comm" = "java" ] && { pid="${d#/proc/}"; break; }
      done
    fi
    echo "$pid"
  ' 2>/dev/null || true)"

  if [[ -z "$pid" ]]; then
    log "DEBUG mode: Java PID not visible from debug container, trying target container..."
    pid="$(detect_java_pid_in_container)"
  fi

  echo "$pid"
}

# Mutates globals: JAVA_PID, MODE_USED
run_debug_mode() {
  local debug_id=""
  local jattach_path=""
  local pid=""

  log "Trying DEBUG mode with toolbox container..."

  validate_remote_dir || die "Remote directory '$REMOTE_DIR' does not exist or is not writable."

  if [[ "$DRY_RUN" = true ]]; then
    log "[DRY-RUN] Would create/reuse ephemeral debug container '$DEBUG_CONTAINER' (image: $TOOL_IMAGE)"
  else
    ensure_debug_container_running

    debug_id="$(kubectl -n "$NS" exec "$POD" -c "$DEBUG_CONTAINER" -- sh -c 'id' 2>/dev/null)" \
      || die "Cannot exec into debug container '$DEBUG_CONTAINER'."
    log "DEBUG mode: debug container identity: $debug_id"

    jattach_path="$(kubectl -n "$NS" exec "$POD" -c "$DEBUG_CONTAINER" -- sh -lc 'command -v jattach 2>/dev/null || true' 2>/dev/null || true)"
    [[ -n "$jattach_path" ]] || die "jattach not found in kheap container. Bake it into the image."
    log "DEBUG mode: jattach: $jattach_path"
  fi

  if [[ -n "$JAVA_PID" ]]; then
    pid="$JAVA_PID"
  else
    log "DEBUG mode: detecting Java PID..."
    if [[ "$DRY_RUN" = true ]]; then
      # Debug container not running in dry-run, detect from target container.
      pid="$(detect_java_pid_in_container)"
    else
      pid="$(debug_detect_java_pid)"
    fi
    [[ -n "$pid" ]] || die "Could not auto-detect Java PID. Provide it with -P <pid>."
  fi

  log "DEBUG mode: using Java PID: $pid"

  verify_remote_space "$pid"

  if [[ "$DRY_RUN" = true ]]; then
    log "[DRY-RUN] Would run: jattach '$pid' dumpheap '$REMOTE_HPROF'"
    JAVA_PID="$pid"
    MODE_USED="DEBUG"
    return 0
  fi

  log "DEBUG mode: creating heap dump with jattach at: $REMOTE_HPROF"
  kubectl -n "$NS" exec "$POD" -c "$DEBUG_CONTAINER" -- sh -lc \
    "$jattach_path '$pid' dumpheap '$REMOTE_HPROF'" \
    || die "Heap dump failed. Cluster policy may block attach/ptrace even for root."

  verify_remote_file_exists || die "Heap dump file not found in target container at '$REMOTE_HPROF'."

  JAVA_PID="$pid"
  MODE_USED="DEBUG"
  return 0
}

# -----------------------------
# Mode selection (heap dump)
# -----------------------------
if [[ "$DEBUG_ONLY" = true ]]; then
  run_debug_mode
elif [[ "$DIRECT_ONLY" = true ]]; then
  run_direct_mode || die "DIRECT mode failed and fallback is disabled by --direct-only."
else
  if run_direct_mode; then
    log "DIRECT mode succeeded."
  else
    warn "DIRECT mode failed or unavailable. Falling back to DEBUG mode."
    run_debug_mode
  fi
fi

# -----------------------------
# Local space check
# Runs in both modes: uses actual remote file size in --force, RSS estimate
# in dry-run. REMOTE_SIZE is set here and reused by verify_size.
# -----------------------------
verify_local_space

# -----------------------------
# Thread dump + copy pipeline: --force mode only
# -----------------------------
if [[ "$DRY_RUN" = false ]]; then
  collect_thread_dump "$JAVA_PID"
  copy_with_retries
  verify_size
  verify_checksum
  OUTPUT_COMPLETE=true
  compress_local_file
  cleanup_remote_file
else
  log "[DRY-RUN] Would collect thread dump for PID $JAVA_PID."
  log "[DRY-RUN] Would copy $REMOTE_HPROF to $LOCAL_HPROF."
  if [[ "$NO_GZIP" = false ]]; then
    log "[DRY-RUN] Would compress to $LOCAL_GZ (gzip -6)."
  fi
  if [[ "$CHECKSUM" = true ]]; then
    log "[DRY-RUN] Would verify MD5 checksum after copy."
  fi
  if [[ "$KEEP_REMOTE" = false ]]; then
    log "[DRY-RUN] Would remove remote file $REMOTE_HPROF after copy."
  fi
fi

# -----------------------------
# Summary
# -----------------------------
gzip_label="$([[ "$NO_GZIP" = false ]] && echo "enabled" || echo "disabled")"
keep_remote_label="$([[ "$KEEP_REMOTE" = true ]] && echo "yes" || echo "no")"
checksum_label="$([[ "$CHECKSUM" = true ]] && echo "yes" || echo "no")"
dryrun_label="$([[ "$DRY_RUN" = true ]] && echo "yes (pass --force to execute)" || echo "no")"

if [[ "$MODE_USED" = "DEBUG" ]]; then
  if [[ "$DRY_RUN" = true ]]; then
    debug_container_label="$DEBUG_CONTAINER (not created, dry-run)"
  else
    debug_container_label="$DEBUG_CONTAINER (REUSE, kept running)"
  fi
  tool_image_label="$TOOL_IMAGE"
else
  debug_container_label="not used"
  tool_image_label="not used"
fi

echo
echo "================== KHEAP SUMMARY =================="
echo "Dry-run          : $dryrun_label"
echo "Mode used        : $MODE_USED"
echo "Namespace        : $NS"
echo "Pod              : $POD"
echo "Target container : $CONTAINER"
echo "Java PID         : $JAVA_PID"
echo "Remote file      : $REMOTE_HPROF"
if [[ "$DRY_RUN" = false ]]; then
  echo "Local heap dump  : $FINAL_FILE"
  if [[ -n "$THREAD_DUMP_FILE" ]]; then
    echo "Thread dump      : $THREAD_DUMP_FILE"
    echo "Thread dump via  : $THREAD_DUMP_METHOD"
  else
    echo "Thread dump      : not collected"
  fi
else
  echo "Local heap dump  : $LOCAL_HPROF (not created)"
  echo "Thread dump      : not collected (dry-run)"
fi
echo "Debug container  : $debug_container_label"
echo "Tool image       : $tool_image_label"
echo "Gzip             : $gzip_label"
echo "Checksum (MD5)   : $checksum_label"
echo "Keep remote      : $keep_remote_label"
echo "==================================================="
echo

trap - EXIT
log "Done."